#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
TOOL_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
JAR_PATH="$TOOL_ROOT/validator_cli.jar"

if [ ! -f "$JAR_PATH" ]; then
  printf 'FHIR validator bundle is incomplete: %s is missing\n' "$JAR_PATH" >&2
  exit 2
fi

set -- "$@"
needs_version=1
needs_tx=1
showing_help=0

for arg in "$@"; do
  case "$arg" in
    -version|--version)
      needs_version=0
      ;;
    -tx)
      needs_tx=0
      ;;
    -help|--help|-h)
      showing_help=1
      ;;
  esac
done

if [ "$showing_help" -eq 0 ]; then
  if [ "$needs_version" -eq 1 ]; then
    set -- "$@" -version 4.0.1
  fi
  if [ "$needs_tx" -eq 1 ]; then
    set -- "$@" -tx n/a
  fi
fi

exec java -jar "$JAR_PATH" "$@"
